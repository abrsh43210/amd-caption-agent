# Copy to .env and fill in your key. Never commit the real .env file.
FIREWORKS_API_KEY=fw_your_key_here

# Optional: residential/mobile proxy for YouTube downloads. YouTube
# blocklists most cloud/datacenter IPs (including Streamlit Community
# Cloud), so a datacenter proxy will hit the same wall — use a
# residential/mobile proxy provider (Webshare, Bright Data, IPRoyal, etc).
# Format: http://user:pass@host:port or socks5://user:pass@host:port
# On Streamlit Cloud, set this in the app's Secrets instead of .env.
YTDLP_PROXY_URL=
